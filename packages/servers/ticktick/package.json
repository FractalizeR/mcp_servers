{
  "name": "@fractalizer/mcp-server-ticktick",
  "version": "0.2.3",
  "description": "MCP Server for TickTick todo-list application",
  "keywords": [
    "mcp",
    "ticktick",
    "todo",
    "task-management",
    "api",
    "claude"
  ],
  "homepage": "https://github.com/FractalizeR/mcp_servers/tree/main/packages/servers/ticktick#readme",
  "bugs": {
    "url": "https://github.com/FractalizeR/mcp_servers/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FractalizeR/mcp_servers.git",
    "directory": "packages/servers/ticktick"
  },
  "license": "PolyForm-Shield-1.0.0",
  "author": "Fractalizer",
  "type": "module",
  "imports": {
    "#config": "./src/config/index.ts",
    "#config/*": "./src/config/*",
    "#ticktick_api/*": "./src/ticktick_api/*",
    "#tools/*": "./src/tools/*",
    "#composition-root/*": "./src/composition-root/*",
    "#cli/*": "./src/cli/*",
    "#constants": "./src/constants.ts",
    "#common/*": "./src/common/*",
    "#integration/*": "./tests/integration/*",
    "#helpers/*": "./tests/helpers/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/ticktick.bundle.cjs": "./dist/ticktick.bundle.cjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcp-server-ticktick": "dist/ticktick.bundle.cjs",
    "mcp-ticktick-connect": "dist/cli/bin/mcp-connect.js"
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "prebuild": "npm run generate:index",
    "build": "tsc -b && tsc-alias && npm run build:bundle",
    "build:bundle": "tsx ../scripts/increment-build.ts && tsup",
    "build:mcpb": "npm run build && tsx ../scripts/build-mcpb.ts",
    "clean": "rimraf dist",
    "cpd": "jscpd src",
    "cpd:quiet": "jscpd src --silent",
    "cpd:report": "jscpd src --reporters html,console",
    "depcruise": "depcruise src -c ../../../.dependency-cruiser.cjs",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "generate:index": "tsx scripts/generate-tool-index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "lint:quiet": "eslint src --ext .ts --quiet",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:quiet": "vitest run --reporter=dot --silent",
    "test:smoke": "vitest run tests/smoke",
    "test:smoke:server": "tsx scripts/smoke-test-server.ts",
    "test:verbose": "vitest run --reporter=verbose",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run test:smoke && npm run test:smoke:server && npm run cpd && npm run depcruise && npm run validate:docs && npm run validate:tools",
    "validate:docs": "tsx ../../../scripts/validate-docs-size.ts",
    "validate:quiet": "npm run lint:quiet && npm run typecheck && npm run test:quiet && npm run cpd:quiet",
    "validate:tools": "tsx scripts/validate-tool-registration.ts"
  },
  "dependencies": {
    "@fractalizer/mcp-cli": "^0.2.2",
    "@fractalizer/mcp-core": "^0.2.2",
    "@fractalizer/mcp-infrastructure": "^0.2.2",
    "@fractalizer/mcp-search": "^0.2.2",
    "@modelcontextprotocol/sdk": "^1.23.0",
    "axios": "^1.13.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "inquirer": "^13.0.1",
    "inversify": "^7.10.4",
    "ora": "^9.0.0",
    "pino": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "axios-mock-adapter": "^2.1.0",
    "tsup": "^8.5.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
