{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.ts"],
      "project": ["scripts/**/*.ts"]
    },
    "packages/framework/infrastructure": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["pino-pretty"]
    },
    "packages/framework/core": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@modelcontextprotocol/sdk",
        "pino",
        "zod-to-json-schema",
        "inversify"
      ]
    },
    "packages/framework/search": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@fractalizer/mcp-infrastructure"]
    },
    "packages/framework/cli": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@fractalizer/mcp-infrastructure",
        "commander"
      ]
    },
    "packages/servers/yandex-tracker": {
      "entry": ["src/index.ts", "src/cli/bin/*.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@fractalizer/mcp-search",
        "@iarna/toml",
        "axios",
        "chalk",
        "inquirer",
        "mime-types",
        "ora",
        "pino"
      ]
    },
    "packages/servers/yandex-wiki": {
      "entry": ["src/index.ts", "src/cli/bin/*.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@fractalizer/mcp-search",
        "axios",
        "chalk",
        "inquirer",
        "pino"
      ]
    },
    "packages/servers/ticktick": {
      "entry": ["src/index.ts", "src/cli/bin/*.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@fractalizer/mcp-search",
        "axios",
        "chalk",
        "inquirer",
        "ora",
        "pino"
      ]
    },
    "packages/wrappers/mcp-server-yandex-tracker": {
      "ignoreDependencies": ["@fractalizer/mcp-server-yandex-tracker"]
    },
    "packages/wrappers/mcp-server-yandex-wiki": {
      "ignoreDependencies": ["@fractalizer/mcp-server-yandex-wiki"]
    },
    "packages/wrappers/mcp-server-ticktick": {
      "ignoreDependencies": ["@fractalizer/mcp-server-ticktick"]
    }
  },
  "ignore": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/tests/**",
    "**/dist/**",
    "**/*.d.ts",
    "vitest.workspace.ts",
    "vitest.shared.ts"
  ],
  "ignoreDependencies": [
    "reflect-metadata"
  ],
  "ignoreExportsUsedInFile": true,
  "includeEntryExports": false,
  "exclude": ["duplicates"]
}
